# =============================================================================
# Media Intelligence Engine - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
WORKERS=4

# --- Analysis ---
DEFAULT_FPS=1.0
DEFAULT_LANGUAGE=es
MAX_FRAMES=500
MAX_DURATION_SECONDS=3600

# --- Directories (relative paths work for Docker volumes) ---
DOWNLOAD_DIR=/data/downloads
RECORDING_DIR=/data/recordings
OUTPUT_DIR=/data/output
TEMP_DIR=/data/temp

# --- Downloaders ---
YT_DLP_PATH=yt-dlp
GALLERY_DL_PATH=gallery-dl
FFMPEG_PATH=ffmpeg

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# --- Whisper (speech-to-text) ---
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# --- OCR ---
OCR_DEVICE=cpu
OCR_LANG=es,en

# --- Vision Providers (al menos uno es necesario para análisis visual) ---
# OpenAI (GPT-4o)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Qwen
QWEN_API_KEY=
QWEN_MODEL=qwen-vl-max

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

# Default vision provider: openai, gemini, anthropic, qwen, ollama
DEFAULT_VISION_PROVIDER=openai

# --- Storage ---
STORAGE_BACKEND=local
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- OpenTelemetry ---
OTEL_SERVICE_NAME=media-intelligence-engine
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_TRACES_SAMPLER=always_on